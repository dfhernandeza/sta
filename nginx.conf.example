# =============================================================
# Nginx configuration for STA Muebles y Terminaciones
# Copy to: /etc/nginx/sites-available/sta
# Enable with: sudo ln -s /etc/nginx/sites-available/sta /etc/nginx/sites-enabled/
# =============================================================

upstream sta_app {
    server 127.0.0.1:8000;
}

# Redirect HTTP → HTTPS
server {
    listen 80;
    server_name tudominio.cl www.tudominio.cl;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name tudominio.cl www.tudominio.cl;

    # --- SSL (replace with your cert paths from Let's Encrypt) ---
    ssl_certificate     /etc/letsencrypt/live/tudominio.cl/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tudominio.cl/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # --- Security headers ---
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options DENY;
    add_header X-XSS-Protection "1; mode=block";
    add_header Referrer-Policy "strict-origin-when-cross-origin";

    # --- Client body ---
    client_max_body_size 20M;

    # --- Static files (served directly by Nginx) ---
    location /static/ {
        alias /var/www/sta/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # --- Media files ---
    location /media/ {
        alias /var/www/sta/media/;
        expires 7d;
    }

    # --- Django app ---
    location / {
        proxy_pass          http://sta_app;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_read_timeout  120s;
        proxy_send_timeout  120s;
    }

    # --- Error pages ---
    error_page 404 /404.html;
    error_page 500 502 503 504 /500.html;
}
